@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@using CourseProject.Data
@using CourseProject.DataModels

@inject EmploymentServiceContext DbContext

<!DOCTYPE html>
<html lang="en">
<head>
    <style>
        .user-initials-circle {
            width: 40px;
            height: 40px;
            background-color: #014898;
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 14px;
            letter-spacing: 1px;
            user-select: none;
            text-decoration: none !important;
            cursor: pointer;
            transition: background-color 0.3s;
        }

        .user-initials-circle:hover {
            text-decoration: none !important; 
            color: white !important;
            background-color: #FF5124;
        }
    </style>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <link rel="icon" type="image/x-icon" href="~/favicon.ico"/>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CourseProject.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        List<CourseProject.DataModels.Notification> dbNotifications = null;

        string fullName;
        string initials = "";

        if (User.Identity.IsAuthenticated)
        {
            fullName = @User.FindFirst("UserFullname").Value;

            if (!string.IsNullOrEmpty(fullName))
            {
                var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                if (parts.Length >= 2)
                {
                    initials = $"{parts[0][0]}{parts[1][0]}".ToUpper();
                }
                else if (parts.Length == 1)
                {
                    initials = parts[0][0].ToString().ToUpper();
                }
            }
        }
    }
    <header class="border-bottom bg-white sticky-top">
        <nav class="navbar navbar-light py-2">
            <div class="container-fluid d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <button class="border-0 p-2 me-2 d-md-none" type="button" style="background: white"
                            data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas">
                        <i class="fa fa-bars fs-4" style="color: #014898"></i>
                    </button>
                    <a class="navbar-brand m-0 p-0" asp-controller="Events" asp-action="Index">
                        <img src="/resources/logo.png" style="height: 40px;" />
                    </a>
                </div>

                <div class="d-flex align-items-center gap-2 gap-md-3">
                    @if (!User.Identity.IsAuthenticated)
                    {
                        <a class="btn btn-sm btn-outline-primary" asp-controller="Auth" asp-action="Login">
                            <i class="fa fa-sign-in"></i> Войти
                        </a>
                    }
                    else
                    {
                        var currentUserId = int.Parse(User.FindFirst("UserId")?.Value);
                        dbNotifications = await DbContext.Notifications
                        .Where(n => n.UserId == currentUserId)
                        .OrderByDescending(n => n.DateCreated)
                        .Take(20).ToListAsync();
                        int unreadCount = dbNotifications.Count(n => !n.IsRead);

                        <div class="dropdown">
                            <button class="btn p-1 position-relative" type="button" id="notificationDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="border: none; background: transparent;">
                                <i class="fa fa-bell" style="font-size: 1.25rem; color: #014898;"></i>
                                <span id="notification-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill"
                                      style="font-size: 0.7rem; padding: 0.25em 0.5em; background-color: #014898; @(unreadCount > 0 ? "" : "display: none;")">
                                    @unreadCount
                                </span>
                            </button>
                            <input type="hidden" id="server-unread-count" value="@unreadCount" />

                            <div class="dropdown-menu dropdown-menu-end shadow p-2 notification-dropdown" aria-labelledby="notificationDropdown">
                                <div class="d-flex justify-content-between align-items-center px-2 py-1 border-bottom">
                                    <h6 class="mb-0 fw-bold" style="color: #014898;">Уведомления</h6>
                                </div>
                                <div id="notification-list" class="mt-2" style="max-height: 350px; overflow-y: auto;">
                                    @if (dbNotifications == null || !dbNotifications.Any())
                                    {
                                        <p class="text-muted text-center my-3" id="no-notifications">Нет новых уведомлений</p>
                                    }
                                    else
                                    {
                                        @foreach (var notif in dbNotifications)
                                        {
                                            <div class="dropdown-item text-wrap border-bottom p-2 position-relative js-notif-item @(notif.IsRead ? "" : "bg-light")"
                                                 id="notif-item-@notif.NotificationId"
                                                 data-id="@notif.NotificationId"
                                                 data-is-read="@notif.IsRead.ToString().ToLower()">
                                                <small class="text-muted">@notif.DateCreated.ToString("dd.MM.yyyy HH:mm")</small>
                                                <p class="mb-0 mt-1 text-dark small">@notif.Message</p>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </div>

                        <a asp-controller="Users" asp-action="Edit" asp-route-id="@User.FindFirst("UserId").Value" class="user-initials-circle">
                            @initials
                        </a>

                        <form class="action-form m-0" asp-controller="Auth" asp-action="Logout">
                            <button type="submit" class="btn" style="color: white" title="Выйти"><i class="fa fa-sign-out text-muted"></i></button>
                        </form>
                    }
                </div>
            </div>
        </nav>

        <div class="offcanvas offcanvas-start d-md-none" tabindex="-1" id="sidebarOffcanvas" style="width: 280px;">
            <div class="offcanvas-header border-bottom">
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
            </div>
            <div class="offcanvas-body p-3">
                <partial name="_SidebarLinks" />
            </div>
        </div>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<script>
    let unreadNotificationsCount = 0;

    const hoverTimers = {};

    document.addEventListener("DOMContentLoaded", function () {
        const serverCountElement = document.getElementById("server-unread-count");
        if (serverCountElement) {
            unreadNotificationsCount = parseInt(serverCountElement.value) || 0;
        }

        document.querySelectorAll(".js-notif-item").forEach(function (item) {
            bindHoverEvent(item);
        });

        initSignalR();
    });

    function bindHoverEvent(element) {
        const id = element.getAttribute("data-id");

        element.addEventListener("mouseenter", function () {
            if (element.getAttribute("data-is-read") === "true") return;

            hoverTimers[id] = setTimeout(async function () {
                await markAsReadServerCall(id, element);
            }, 800);
        });

        element.addEventListener("mouseleave", function () {
            if (hoverTimers[id]) {
                clearTimeout(hoverTimers[id]);
                delete hoverTimers[id];
            }
        });
    }

    async function markAsReadServerCall(id, element) {
        try {
            const response = await fetch(`/Notifications/MarkAsRead?id=${id}`, { method: 'POST' });

            if (response.ok) {
                element.classList.remove('bg-light');
                element.setAttribute("data-is-read", "true");

                if (hoverTimers[id]) delete hoverTimers[id];

                if (unreadNotificationsCount > 0) {
                    unreadNotificationsCount--;
                    updateNotificationBadge();
                }
            } else {
                console.error("Сервер ответил ошибкой при попытке прочесть уведомление ID: " + id);
            }
        } catch (error) {
            console.error("Ошибка сети при отправке статуса прочтения:", error);
        }
    }

    function initSignalR() {
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveNotificationObj", function (notification) {
            const listContainer = document.getElementById("notification-list");

            const noNotificationsText = document.getElementById("no-notifications");
            if (noNotificationsText) {
                noNotificationsText.remove();
            }

            const item = document.createElement("div");
            item.className = "dropdown-item text-wrap border-bottom p-2 position-relative js-notif-item bg-light";
            item.id = `notif-item-${notification.id}`;
            item.setAttribute("data-id", notification.id);
            item.setAttribute("data-is-read", "false");
            item.style.cursor = "default";
            item.style.whiteSpace = "normal";
            item.style.transition = "background-color 0.5s ease";

            const dateFormatted = new Date(notification.createdAt).toLocaleString();

            item.innerHTML = `
                <div class="d-flex justify-content-between align-items-start">
                    <small class="text-muted" style="font-size: 0.75rem;">${dateFormatted}</small>
                </div>
                <p class="mb-0 mt-1 text-dark" style="font-size: 0.85rem; line-height: 1.3;">
                    ${notification.message}
                </p>
            `;

            listContainer.insertBefore(item, listContainer.firstChild);

            bindHoverEvent(item);

            unreadNotificationsCount++;
            updateNotificationBadge();
        });

        connection.start()
            .then(() => console.log("SignalR успешно подключен к хабу."))
            .catch(err => console.error("Ошибка запуска SignalR: ", err.toString()));
    }

    function updateNotificationBadge() {
        const badge = document.getElementById("notification-badge");
        if (badge) {
            if (unreadNotificationsCount > 0) {
                badge.innerText = unreadNotificationsCount;
                badge.style.display = "block";
            } else {
                badge.style.display = "none";
            }
        }
    }
</script>
